<h1 class="mb-4">New Task</h1>


<%= form_with model: @task do |f| %>
  <%= f.label :title %>
  <%= f.text_field :title %>

  <%= f.label :details %>
  <%= f.text_field :details %>

  <%= f.submit "Create Task", class: "btn btn-primary" %>
<% end %>

<%= link_to "Back to list", tasks_path, class: "btn btn-primary" %>
