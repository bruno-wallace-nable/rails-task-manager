<h1 class="mb-4">My Tasks</h1>

<ul>
  <% @tasks.each do |task| %>
    <li>
      <%= check_box_tag "task_#{task.id}", "1", task.completed, disabled: true %>
      <%= link_to task.title, task_path(task) %>
      | <%= link_to "Delete", task_path(task), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" }, class: "btn btn-primary" %>
    </li>
  <% end %>
</ul>

<hr>
<%= link_to "Add a new task", new_task_path, class: "btn btn-primary" %>
