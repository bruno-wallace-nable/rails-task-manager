<h1 class="mb-4"><%= @task.title %></h1>
<p class="mb-4"><%= @task.details %></p>

<p>
  <strong>Status:</strong>
  <%= @task.completed ? "Completed" : "Incomplete" %>
</p>

<hr>
<%= link_to "Edit this task", edit_task_path(@task), class: "btn btn-primary" %> |
<%= link_to "Back to list", tasks_path, class: "btn btn-primary" %>
